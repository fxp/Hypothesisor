{
  "manifest_version": 3,
  "name": "Hypothesisor",
  "version": "0.1.0",
  "description": "用 GLM 读懂当前网页，一键在 Hypothesis 上生成高质量标注。",
  "action": {
    "default_popup": "popup.html",
    "default_title": "Hypothesisor"
  },
  "options_page": "options.html",
  "permissions": ["activeTab", "scripting", "storage"],
  "host_permissions": [
    "https://api.hypothes.is/*",
    "https://open.bigmodel.cn/*"
  ],
  "icons": {
    "16": "icons/icon.svg",
    "48": "icons/icon.svg",
    "128": "icons/icon.svg"
  }
}
