{
  "manifest_version": 3,
  "name": "__MSG_extName__",
  "version": "0.1.10",
  "description": "__MSG_extDesc__",
  "default_locale": "en",
  "action": {
    "default_popup": "popup.html",
    "default_title": "__MSG_extName__",
    "default_icon": {
      "16": "icons/icon-16.png",
      "32": "icons/icon-32.png",
      "48": "icons/icon-48.png",
      "128": "icons/icon-128.png"
    }
